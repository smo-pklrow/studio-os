# Supabase — get these from your project's API settings
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Anthropic — for the Claude API calls (server-side only via Supabase Edge Functions)
# Do NOT prefix with VITE_ — this must never be exposed to the browser
ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth — set up in Google Cloud Console
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# App
VITE_APP_URL=http://localhost:5173
